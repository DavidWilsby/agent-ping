{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/bin/cli.js\" stop \"${CLAUDE_PLUGIN_DATA}\""
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/bin/cli.js\" notification \"${CLAUDE_PLUGIN_DATA}\""
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/bin/cli.js\" notification \"${CLAUDE_PLUGIN_DATA}\""
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/bin/cli.js\" notification \"${CLAUDE_PLUGIN_DATA}\""
          }
        ]
      }
    ]
  }
}
